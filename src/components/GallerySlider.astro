---
interface GalleryImage {
  src: string
  alt: string
}

interface Props {
  images: GalleryImage[]
}

const { images } = Astro.props
const slideCount = images.length
---
{images.length > 0 && (
  <div class="gallery-slider-wrap relative select-none" data-gallery-slider>
    <div class="swiper">
      <div class="swiper-wrapper">
        {images.map((img) => (
          <div class="swiper-slide !h-auto">
            <div class="overflow-hidden">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full aspect-[4/3] object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        ))}
      </div>
    </div>

    {slideCount > 1 && (
      <>
        <button type="button" class="btn-prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <button type="button" class="btn-next" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </button>
        <div class="pagination-dots" />
      </>
    )}
  </div>
)}

<style>
  .gallery-slider-wrap {
    position: relative;
  }

  /* 自定义导航按钮 */
  .btn-prev,
  .btn-next {
    position: absolute;
    top: 50%;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-top: -22px;
    border: none;
    border-radius: 9999px;
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: 0 2px 12px var(--color-shadow);
    cursor: pointer;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .btn-prev svg,
  .btn-next svg {
    width: 20px;
    height: 20px;
  }
  .btn-prev { left: 4px; }
  .btn-next { right: 4px; }
  .btn-prev:hover,
  .btn-next:hover {
    background: var(--color-primary-500);
    color: #fff;
    box-shadow: 0 4px 16px rgba(0, 110, 255, 0.3);
    transform: scale(1.08);
  }
  .btn-prev:active,
  .btn-next:active {
    transform: scale(0.95);
  }

  @media (max-width: 767px) {
    .btn-prev, .btn-next {
      width: 36px;
      height: 36px;
      margin-top: -18px;
    }
    .btn-prev svg, .btn-next svg {
      width: 16px;
      height: 16px;
    }
  }

  /* 自定义分页指示器 */
  .pagination-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .pagination-dots :global(.swiper-pagination-bullet) {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-text-subtle);
    opacity: 0.5;
    cursor: pointer;
    transition: all 0.3s ease;
    margin: 0 !important;
  }
  .pagination-dots :global(.swiper-pagination-bullet-active) {
    width: 28px;
    border-radius: 4px;
    background: var(--color-primary-500);
    opacity: 1;
  }
</style>

<script>
  import Swiper from 'swiper'
  import { Navigation, Pagination, Autoplay } from 'swiper/modules'
  import 'swiper/css'

  document.querySelectorAll('[data-gallery-slider]').forEach((el) => {
    const swiperEl = el.querySelector('.swiper') as HTMLElement
    if (!swiperEl) return

    new Swiper(swiperEl, {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 0,
      centeredSlides: true,
      loop: true,
      speed: 500,
      autoplay: {
        delay: 3500,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      navigation: {
        nextEl: el.querySelector('.btn-next') as HTMLElement,
        prevEl: el.querySelector('.btn-prev') as HTMLElement
      },
      pagination: {
        el: el.querySelector('.pagination-dots') as HTMLElement,
        clickable: true
      },
      breakpoints: {
        768: {
          slidesPerView: 2,
          spaceBetween: 0
        }
      }
    })
  })
</script>
