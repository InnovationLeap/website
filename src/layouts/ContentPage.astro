---
import { type Lang, ui } from '../i18n/ui'
import { getEntry, render } from 'astro:content'
import BaseLayout from './BaseLayout.astro'
import SubNav from '../components/SubNav.astro'

interface SubNavItem {
  text: string
  href: string
  active?: boolean
}

interface Props {
  lang: Lang
  page: string
}

const { lang, page } = Astro.props

// 获取 Markdown 内容
const entry = await getEntry('pages', `${lang}/${page}`)
if (!entry) {
  return Astro.redirect('/404')
}
const { Content } = await render(entry)
const title = entry.data.title

// 根据 page 类型计算 subnav 项
function getSubnavItems(lang: Lang, page: string): SubNavItem[] {
  if (page === 'about' || page === 'team') {
    return [
      { text: lang === 'cn' ? '简介' : 'About us', href: `/${lang}/about/`, active: page === 'about' },
      { text: lang === 'cn' ? '团队' : 'Our team', href: `/${lang}/about/team/`, active: page === 'team' }
    ]
  }
  if (page === 'legend-world-remake' || page === 'changelog') {
    return [
      { text: lang === 'cn' ? '概述' : 'Overview', href: `/${lang}/legend-world-remake/`, active: page === 'legend-world-remake' },
      { text: lang === 'cn' ? '更新日志' : 'Changelog', href: `/${lang}/legend-world-remake/changelog/`, active: page === 'changelog' },
      { text: lang === 'cn' ? '了解原版' : 'MW 1.1 edition', href: `/${lang}/legend-world-remake/legend-world-on-mario-worker/`, active: false }
    ]
  }
  if (page === 'legend-world-on-mario-worker') {
    return [
      { text: lang === 'cn' ? '概述' : 'Overview', href: `/${lang}/legend-world-remake/legend-world-on-mario-worker/`, active: true },
      { text: lang === 'cn' ? '了解重制版' : 'Remake', href: `/${lang}/legend-world-remake/`, active: false }
    ]
  }
  return []
}

// 计算 SubNav 标题
function getSubnavTitle(lang: Lang, page: string): string {
  if (page === 'about' || page === 'team') return lang === 'cn' ? '关于' : 'About'
  if (page === 'legend-world-remake' || page === 'changelog' || page === 'legend-world-on-mario-worker') return lang === 'cn' ? 'Legend World Remake' : 'Legend World Remake'
  return ''
}

// 计算下载链接
function getDownloadConfig(lang: Lang, page: string) {
  const langData = ui[lang]
  if (page === 'legend-world-remake' || page === 'changelog') return langData.legendWorldRemake
  if (page === 'legend-world-on-mario-worker') return langData.legendWorldMW
  return { downloadUrl: '', downloadText: '' }
}

const subnavItems = getSubnavItems(lang, page)
const subnavTitle = title || getSubnavTitle(lang, page)
const { downloadUrl, downloadText } = getDownloadConfig(lang, page)
const pageTitle = `${title} - INNOVATION LEAP`
---

<BaseLayout lang={lang} title={pageTitle} headerSticky={false}>
  <SubNav items={subnavItems} title={subnavTitle} downloadUrl={downloadUrl} downloadText={downloadText} />
  <div class="max-w-7xl mx-auto px-6 py-6">
    <article class="prose-content" data-content>
      <Content />
    </article>
  </div>
</BaseLayout>

<style>
  /* 内容区域样式 */
  .prose-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .prose-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .prose-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .prose-content :global(p) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }
  .prose-content :global(a) {
    color: var(--color-primary-500);
    text-underline-offset: 2px;
  }
  .prose-content :global(a:hover) {
    color: var(--color-primary-400);
    text-decoration: underline;
  }
  .prose-content :global(ul), .prose-content :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul) { list-style: disc; }
  .prose-content :global(ol) { list-style: decimal; }
  .prose-content :global(li) {
    line-height: 1.75;
  }
  .prose-content :global(blockquote) {
    border-left: 4px solid var(--color-primary-500);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .prose-content :global(code) {
    background: var(--color-bg-muted);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .prose-content :global(pre) {
    background: var(--color-bg-muted);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .prose-content :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }
  .prose-content :global(th), .prose-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .prose-content :global(th) {
    background: var(--color-bg-muted);
    font-weight: 600;
  }
  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: 1rem 0;
  }
  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-content :global(iframe) {
    width: 100%;
    aspect-ratio: 16/9;
    border: none;
    border-radius: 0.5rem;
    margin: 1rem 0;
  }
  /* 表格响应式 */
  .prose-content :global(.table-responsive) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* 画廊轮播组件样式（与 GallerySlider.astro 一致）*/
  .prose-content :global(.gallery-slider-wrap) {
    position: relative;
  }
  .prose-content :global(.btn-prev),
  .prose-content :global(.btn-next) {
    position: absolute;
    top: 50%;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-top: -22px;
    border: none;
    border-radius: 9999px;
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: 0 2px 12px var(--color-shadow);
    cursor: pointer;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .prose-content :global(.btn-prev) { left: 4px; }
  .prose-content :global(.btn-next) { right: 4px; }
  .prose-content :global(.btn-prev:hover),
  .prose-content :global(.btn-next:hover) {
    background: var(--color-primary-500);
    color: #fff;
    box-shadow: 0 4px 16px rgba(0, 110, 255, 0.3);
    transform: scale(1.08);
  }
  .prose-content :global(.btn-prev svg),
  .prose-content :global(.btn-next svg) {
    width: 20px;
    height: 20px;
  }
  @media (max-width: 767px) {
    .prose-content :global(.btn-prev),
    .prose-content :global(.btn-next) {
      width: 36px;
      height: 36px;
      margin-top: -18px;
    }
    .prose-content :global(.btn-prev svg),
    .prose-content :global(.btn-next svg) {
      width: 16px;
      height: 16px;
    }
  }
  .prose-content :global(.pagination-dots) {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .prose-content :global(.pagination-dots .swiper-pagination-bullet) {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-text-subtle);
    opacity: 0.5;
    cursor: pointer;
    transition: all 0.3s ease;
    margin: 0 !important;
  }
  .prose-content :global(.pagination-dots .swiper-pagination-bullet-active) {
    width: 28px;
    border-radius: 4px;
    background: var(--color-primary-500);
    opacity: 1;
  }
</style>

<script>
  import Swiper from 'swiper'
  import { Navigation, Pagination, Autoplay } from 'swiper/modules'
  import 'swiper/css'

  // 1. 增强图片画廊 - 将 .image-gallery 转换为 Swiper 轮播
  function enhanceGalleries() {
    const galleries = document.querySelectorAll('.image-gallery')
    galleries.forEach(gallery => {
      const imgs = Array.from(gallery.querySelectorAll('img'))
      if (imgs.length === 0) return

      const images = imgs.map(img => ({
        src: img.getAttribute('src') || '',
        alt: img.getAttribute('alt') || ''
      }))

      // 创建 Swiper 结构（与 GallerySlider.astro 一致）
      const wrap = document.createElement('div')
      wrap.className = 'gallery-slider-wrap relative select-none'
      wrap.setAttribute('data-gallery-slider', '')

      const swiperEl = document.createElement('div')
      swiperEl.className = 'swiper'

      const wrapper = document.createElement('div')
      wrapper.className = 'swiper-wrapper'

      images.forEach(img => {
        const slide = document.createElement('div')
        slide.className = 'swiper-slide !h-auto'
        const inner = document.createElement('div')
        inner.className = 'overflow-hidden'
        const imgEl = document.createElement('img')
        imgEl.src = img.src
        imgEl.alt = img.alt
        imgEl.className = 'w-full aspect-[4/3] object-cover'
        imgEl.loading = 'lazy'
        imgEl.decoding = 'async'
        inner.appendChild(imgEl)
        slide.appendChild(inner)
        wrapper.appendChild(slide)
      })

      swiperEl.appendChild(wrapper)
      wrap.appendChild(swiperEl)

      // 如果有多张图片，添加导航控件
      if (images.length > 1) {
        const prevBtn = document.createElement('button')
        prevBtn.type = 'button'
        prevBtn.className = 'btn-prev'
        prevBtn.setAttribute('aria-label', 'Previous')
        prevBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>'
        wrap.appendChild(prevBtn)

        const nextBtn = document.createElement('button')
        nextBtn.type = 'button'
        nextBtn.className = 'btn-next'
        nextBtn.setAttribute('aria-label', 'Next')
        nextBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>'
        wrap.appendChild(nextBtn)

        const paginationEl = document.createElement('div')
        paginationEl.className = 'pagination-dots'
        wrap.appendChild(paginationEl)
      }

      // 替换原始 gallery
      gallery.innerHTML = ''
      gallery.appendChild(wrap)
    })

    // 初始化所有 Swiper 实例
    initSliders()
  }

  // 2. 初始化 Swiper 轮播
  function initSliders() {
    document.querySelectorAll('[data-gallery-slider]').forEach((wrap) => {
      const swiperEl = wrap.querySelector('.swiper') as HTMLElement & { swiper?: Swiper }
      if (!swiperEl || swiperEl.swiper) return

      new Swiper(swiperEl, {
        modules: [Navigation, Pagination, Autoplay],
        slidesPerView: 1,
        spaceBetween: 0,
        centeredSlides: true,
        loop: true,
        speed: 500,
        autoplay: {
          delay: 3500,
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        },
        navigation: {
          nextEl: wrap.querySelector('.btn-next') as HTMLElement,
          prevEl: wrap.querySelector('.btn-prev') as HTMLElement
        },
        pagination: {
          el: wrap.querySelector('.pagination-dots') as HTMLElement,
          clickable: true
        },
        breakpoints: {
          768: {
            slidesPerView: 2,
            spaceBetween: 0
          }
        }
      })
    })
  }

  // 3. 表格响应式包裹
  function enhanceTables() {
    const tables = document.querySelectorAll('.prose-content table')
    tables.forEach(table => {
      const parent = table.parentNode as HTMLElement | null
      if (parent && parent.classList.contains('table-responsive')) return
      const wrap = document.createElement('div')
      wrap.className = 'table-responsive'
      wrap.style.overflowX = 'auto'
      wrap.style.setProperty('-webkit-overflow-scrolling', 'touch')
      table.parentNode?.insertBefore(wrap, table)
      wrap.appendChild(table)
    })
  }

  // 执行增强
  enhanceGalleries()
  enhanceTables()
</script>
